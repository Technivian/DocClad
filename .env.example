DJANGO_ENV=development
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_LOG_LEVEL=INFO
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0
CSRF_TRUSTED_ORIGINS=
INTERNAL_IPS=127.0.0.1
DEFAULT_FROM_EMAIL=noreply@example.com
SERVER_EMAIL=noreply@example.com
SECURE_SSL_REDIRECT=false

# Database
# Local development defaults to SQLite if DATABASE_URL is unset.
# Production should set DATABASE_URL to a PostgreSQL DSN.
#
# Optional local diagnostics. Keep false during visual validation so the
# Django Debug Toolbar does not alter screenshots or layout measurements.
DJANGO_DEBUG_TOOLBAR=false

# Safety guard (config/settings_development.py): in development, DATABASE_URL
# must point at a local host (sqlite, or Postgres on localhost/127.0.0.1) or
# the app refuses to start — this prevents a dev server or `manage.py test`
# from silently connecting to a shared/remote database just because a real
# DATABASE_URL happens to be sitting in this file. To intentionally point
# local dev at a remote database, set ALLOW_REMOTE_DATABASE=true below.
# `manage.py test` additionally always forces an in-memory sqlite database
# regardless of DATABASE_URL; ALLOW_REMOTE_TEST_DB=true overrides that too,
# but should not normally be needed.
DATABASE_URL=
DB_CONN_MAX_AGE=60
DB_SSL_REQUIRE=false
ALLOW_REMOTE_DATABASE=false
ALLOW_REMOTE_TEST_DB=false

SSO_ENABLED=false
OIDC_RP_CLIENT_ID=
OIDC_RP_CLIENT_SECRET=
OIDC_OP_DISCOVERY_ENDPOINT=
OIDC_VERIFY_SSL=true

SAML_ENABLED=false
SAML_SP_ENTITY_ID=
SAML_SP_X509_CERT=
SAML_SP_PRIVATE_KEY=

# Governed AI clause extraction. Both this deployment switch and the
# workspace AI policy must be enabled before contract text is sent.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_AI_ENABLED=false

# Controlled internal pilot lock (nav + route denylist for excluded surfaces).
CONTROLLED_PILOT_ENABLED=false
BILLING_SELF_SERVE_ENABLED=true
TRUST_ACCOUNTING_ENABLED=true

# Scheduler observability
REMINDER_SCHEDULER_EXPECTED_INTERVAL_MINUTES=60
REMINDER_SCHEDULER_STALE_MULTIPLIER=2
REQUEST_METRICS_ENABLED=true
HEALTH_DB_LATENCY_WARN_MS=250
HEALTH_DB_LATENCY_FAIL_MS=1500
SLO_API_P95_MS=500
SLO_5XX_RATE_WARN_PCT=0.8
SLO_5XX_RATE_FAIL_PCT=2.0
LOG_SINK_ENABLED=false
LOG_SINK_URL=
LOG_SINK_TIMEOUT_SECONDS=2.0

# Salesforce OAuth (Sprint 1 foundation)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_AUTHORIZATION_URL=https://login.salesforce.com/services/oauth2/authorize
SALESFORCE_TOKEN_URL=https://login.salesforce.com/services/oauth2/token
SALESFORCE_REDIRECT_URI=
SALESFORCE_SCOPES=api refresh_token offline_access
SALESFORCE_TOKEN_ENCRYPTION_SALT=salesforce-tokens-v1
SALESFORCE_API_VERSION=61.0
SALESFORCE_SYNC_DEFAULT_LIMIT=200

# NetSuite authenticated sync (Sprint 3)
NETSUITE_CLIENT_ID=
NETSUITE_CLIENT_SECRET=
NETSUITE_TOKEN_URL=
NETSUITE_API_URL=
NETSUITE_TIMEOUT_SECONDS=30
ESIGN_WEBHOOK_SECRET=

# PAR-ID-001 process-role flags (all default off)
PROCESS_ROLE_SHADOW_WRITE_ENABLED=false
PROCESS_ROLE_PARITY_REPORTING_ENABLED=false
PROCESS_ROLE_RESOLVER_PARITY_ENABLED=false
PROCESS_ROLE_CANONICAL_RESOLVER_ENABLED=false
PROCESS_ROLE_CANONICAL_RESOLVER_ORG_ALLOWLIST=
